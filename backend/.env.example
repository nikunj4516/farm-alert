PORT=8787
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional AI layer. If missing, the pipeline stores verified RSS summaries without invented content.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
NEWS_AI_ENABLED=false
NEWS_TARGET_LANGUAGES=en

# Optional comma-separated custom RSS/API configuration can be added later.
NEWSAPI_KEY=
NEWS_FETCH_CRON=*/30 * * * *
NEWS_FETCH_ON_START=false
NEWS_MAX_ITEMS_PER_SOURCE=20
